# -----------------------------------------------------------------------------
# Local (.env.local) — npm run dev
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Vercel → Settings → Environment Variables → Environment: Production
# (Preview pode ficar vazio: o app usa o host *.vercel.app nos previews)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://kazaro.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tdrgjxlmlotheamyeznz.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Opcional (só servidor): confere e-mail duplicado antes do cadastro em profiles.
# Também necessária para o usuário poder EXCLUIR A PRÓPRIA CONTA em Configurações.
# Project Settings → API → service_role (nunca expor no cliente).
# SUPABASE_SERVICE_ROLE_KEY=

# LGPD / documentos legais (exibidos na Política de Privacidade e Termos)
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=privacidade@suaempresa.com.br
# NEXT_PUBLIC_DPO_TITLE=Encarregado de dados (Kazaro)
# NEXT_PUBLIC_CONTROLLER_LEGAL_NOTE=Razão Social XYZ, CNPJ 00.000.000/0001-00, endereço...

# Resend (opcional): e-mail em suporte + quando o status do agendamento muda (cliente)
# RESEND_API_KEY=
# RESEND_FROM=Kazaro <no-reply@kazaro.app>

# Supabase → Authentication → URL Configuration
#   Site URL: https://kazaro.app
# Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://kazaro.app/auth/callback
#   https://www.kazaro.app/auth/callback
