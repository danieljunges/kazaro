# -----------------------------------------------------------------------------
# Local (.env.local) — npm run dev
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Vercel → Settings → Environment Variables → Environment: Production
# (Preview pode ficar vazio: o app usa o host *.vercel.app nos previews)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://kazaro.app
#
# Link de confirmar e-mail: o cadastro no browser usa window.location se esta var
# não existir no build — mas defina NEXT_PUBLIC_SITE_URL em produção (e-mails, SEO).
# No Supabase → Auth → URL Configuration, inclua exatamente:
#   https://kazaro.app/auth/callback
#   (+ preview) https://*.vercel.app/auth/callback

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tdrgjxlmlotheamyeznz.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Opcional (só servidor): confere e-mail duplicado antes do cadastro em profiles.
# Também necessária para o usuário poder EXCLUIR A PRÓPRIA CONTA em Configurações.
# Project Settings → API → service_role (nunca expor no cliente).
# SUPABASE_SERVICE_ROLE_KEY=

# LGPD / documentos legais (exibidos na Política de Privacidade e Termos)
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=privacidade@suaempresa.com.br
# NEXT_PUBLIC_DPO_TITLE=Encarregado de dados (Kazaro)
# NEXT_PUBLIC_CONTROLLER_LEGAL_NOTE=Razão Social XYZ, CNPJ 00.000.000/0001-00, endereço...

# Resend: e-mails do app (suporte, status de pedido, serviço aprovado/reprovado na moderação).
# Sem RESEND_API_KEY, a moderação continua funcionando, mas o prestador não recebe e-mail.
# RESEND_API_KEY=
# RESEND_FROM=Kazaro <no-reply@kazaro.app>
#
# SUPABASE_SERVICE_ROLE_KEY ajuda a achar o e-mail do prestador em auth.users se profiles.email estiver vazio.

# Stripe (teste: Dashboard → Developers → API keys, modo Test)
# Secret só no servidor — nunca NEXT_PUBLIC_ na sk_.
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Webhook: Developers → Webhooks → POST .../api/stripe/webhook → Signing secret
# STRIPE_WEBHOOK_SECRET=

# Supabase → Authentication → URL Configuration
#   Site URL: https://kazaro.app
# Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://kazaro.app/auth/callback
#   https://www.kazaro.app/auth/callback
#
# Link de confirmação por e-mail — tempo até expirar:
#   No painel do Supabase (Authentication → configurações do projeto), o padrão costuma ser
#   cerca de 1 hora, não 10 minutos. Para mudar (ex.: 600 s = 10 min), use as opções avançadas
#   do Auth no Supabase; isso não se configura neste arquivo Next.js.
